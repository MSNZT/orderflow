APP_ENV=local # local | production

POSTGRES_USER=orderflow
POSTGRES_PASSWORD=orderflow
POSTGRES_DB=orderflow
POSTGRES_PORT=5432

HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=30s

POSTGRES_DSN=postgres://orderflow:orderflow@postgres:5432/orderflow?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=0
POSTGRES_MAX_CONN_LIFETIME=30m

JWT_SECRET=secret-jwt-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

PAYMENT_TTL=5m
EXPIRE_INTERVAL=1m
EXPIRE_BATCH_LIMIT=100

#Grafana
GRAFANA_ADMIN_USER=grafana_admin_example
GRAFANA_ADMIN_PASSWORD=grafana_admin_password
GRAFANA_ALLOW_SIGN_UP=false

# Yookassa
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_SHOP_ID=shop_id
YOOKASSA_SECRET_KEY=secret_key
YOOKASSA_RETURN_URL=http://localhost:3000/payment/result
YOOKASSA_REQUEST_TIMEOUT=10s